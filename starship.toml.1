add_newline = false

format = """
[╭─](white)$username$hostname > $directory$battery$cmd_duration
[╰─](white)$character """

scan_timeout = 10

[username]
show_always = true
style_root = "bold red"
style_user = "bold yellow"
format = "[$user]($style) "
disabled = false

[hostname]
ssh_only = false
format =  "[$hostname](bold red)"
trim_at = ".companyname.com"
disabled = false

[directory]
read_only = "🔒"
style = "bold cyan"
read_only_style = "red"
truncation_length = 8
truncation_symbol = "…/"
format = "[$read_only]($read_only_style)[$path]($style) "
disabled = false
 
[battery]
format = 	'[$symbol$percentage]'

[[battery.display]]
threshold = 100

[cmd_duration]
show_milliseconds = true
format = [$duration](bold yellow)"

[character]
format = "$symbol"
success_symbol = "[❯](bold green)"
error_symbol = "[✗](bold red) "
disabled = false
